{
  "name": "banco-carrefour-api-tests",
  "version": "1.0.0",
  "description": "Automated API tests for the Banco Carrefour technical challenge",
  "scripts": {
    "test": "jest --runInBand",
    "test:verbose": "jest --verbose",
    "test:login": "jest --testPathPattern=auth",
    "test:users": "jest --testPathPattern=users",
    "test:contracts": "jest --testPathPattern=contracts",
    "test:security": "jest --testPathPattern=security",
    "test:idempotency": "jest --testPathPattern=idempotency",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write 'src/**/*.js' 'tests/**/*.js'",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "keywords": [
    "api-testing",
    "jest",
    "supertest",
    "qa",
    "automation"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^8.4.1",
    "dotenv": "^17.3.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-html-reporters": "^3.1.7",
    "jest-json-schema": "^6.1.0",
    "jest-junit": "^16.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2"
  }
}
